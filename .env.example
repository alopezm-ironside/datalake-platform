# Odoo connection
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_database
ODOO_USER=your_user
ODOO_PASSWORD=your_password

# Google Cloud
GOOGLE_CREDENTIAL_SERVICE_FILE=/path/to/service_credentials.json
GOOGLE_PROJECT_ID=your-gcp-project
GOOGLE_LOCATION=US

# BigQuery datasets
BQ_DATASET_RAW=odoo_raw
BQ_DATASET_CONTROL=control
